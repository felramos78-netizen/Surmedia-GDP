generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// Razones Sociales (BUK multi-empresa)
// ─────────────────────────────────────────────

enum LegalEntity {
  COMUNICACIONES_SURMEDIA
  SURMEDIA_CONSULTORIA
}

// ─────────────────────────────────────────────
// Auth & Usuarios
// ─────────────────────────────────────────────

enum UserRole {
  ADMIN
  RRHH_MANAGER
  RRHH_ANALYST
  MANAGER
  EMPLOYEE
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  role         UserRole  @default(EMPLOYEE)
  avatarUrl    String?
  googleId     String?   @unique
  microsoftId  String?   @unique
  passwordHash String?
  employee     Employee? @relation(fields: [employeeId], references: [id])
  employeeId   String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("users")
}

// ─────────────────────────────────────────────
// Estructura Organizacional
// ─────────────────────────────────────────────

model Department {
  id        String      @id @default(uuid())
  name      String
  code      String      @unique
  parent    Department? @relation("DeptHierarchy", fields: [parentId], references: [id])
  parentId  String?
  children  Department[] @relation("DeptHierarchy")
  positions Position[]
  employees Employee[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("departments")
}

model Position {
  id           String     @id @default(uuid())
  title        String
  level        String?
  department   Department @relation(fields: [departmentId], references: [id])
  departmentId String
  employees    Employee[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("positions")
}

// ─────────────────────────────────────────────
// Colaboradores
// ─────────────────────────────────────────────

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  DUPLICATE
}

enum ContractType {
  INDEFINIDO
  PLAZO_FIJO
  HONORARIOS
  PRACTICA
}

// ─────────────────────────────────────────────
// Centros de Trabajo
// ─────────────────────────────────────────────

enum CostType {
  DIRECTO
  INDIRECTO
}

model WorkCenter {
  id          String               @id @default(uuid())
  name        String               @unique
  costType    CostType             @default(DIRECTO)
  assignments EmployeeWorkCenter[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@map("work_centers")
}

model EmployeeWorkCenter {
  id           String      @id @default(uuid())
  employee     Employee    @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId   String
  workCenter   WorkCenter  @relation(fields: [workCenterId], references: [id], onDelete: Cascade)
  workCenterId String
  legalEntity  LegalEntity
  createdAt    DateTime    @default(now())

  @@unique([employeeId, workCenterId, legalEntity])
  @@map("employee_work_centers")
}

model Employee {
  id           String         @id @default(uuid())
  rut          String         @unique
  firstName    String
  lastName     String
  email        String         @unique
  phone        String?
  birthDate    DateTime?
  address      String?
  nationality  String?        @default("Chilena")
  gender       String?

  position     Position?      @relation(fields: [positionId], references: [id])
  positionId   String?
  department   Department?    @relation(fields: [departmentId], references: [id])
  departmentId String?
  manager      Employee?      @relation("ReportsTo", fields: [managerId], references: [id])
  managerId    String?
  reports      Employee[]     @relation("ReportsTo")
  status       EmployeeStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime?

  afp          String?
  isapre       String?
  previredCode String?

  // Campos extendidos desde BUK
  city           String?
  commune        String?
  personalEmail  String?
  workSchedule   String?
  supervisorName  String?
  supervisorTitle String?
  jobFamily      String?   // Familia de Cargo (role_family)
  jobTitle       String?   // Cargo directo (role.name)
  costCenter     String?   // Centro / proyecto (current_job.cost_center)
  exclusive      Boolean?  // Exclusividad laboral
  vinculo        String?   // Planta, Reemplazo, etc.
  reemplazaA     String?   // Nombre del colaborador que reemplaza (solo si vínculo=Reemplazo)

  user           User?
  contracts      Contract[]
  leaves         Leave[]
  documents      Document[]
  payrollEntries      PayrollEntry[]
  onboardingProcesses OnboardingProcess[]
  workCenters    EmployeeWorkCenter[]

  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@map("employees")
}

// ─────────────────────────────────────────────
// Contratos
// ─────────────────────────────────────────────

model Contract {
  id           String       @id @default(uuid())
  employee     Employee     @relation(fields: [employeeId], references: [id])
  employeeId   String
  type         ContractType
  startDate    DateTime
  endDate      DateTime?
  salary       Int
  currency     String       @default("CLP")
  isActive     Boolean      @default(true)
  fileUrl      String?

  legalEntity  LegalEntity?
  bukEmployeeId Int?
  grossSalary  Int?

  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("contracts")
}

// ─────────────────────────────────────────────
// Vacaciones y Permisos
// ─────────────────────────────────────────────

enum LeaveType {
  VACACIONES
  PERMISO
  LICENCIA_MEDICA
  LICENCIA_MATERNIDAD
  LICENCIA_PATERNIDAD
  OTRO
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model Leave {
  id          String      @id @default(uuid())
  employee    Employee    @relation(fields: [employeeId], references: [id])
  employeeId  String
  type        LeaveType
  startDate   DateTime
  endDate     DateTime
  days        Int
  reason      String?
  status      LeaveStatus @default(PENDING)
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("leaves")
}

// ─────────────────────────────────────────────
// Documentos
// ─────────────────────────────────────────────

model Document {
  id          String   @id @default(uuid())
  employee    Employee @relation(fields: [employeeId], references: [id])
  employeeId  String
  name        String
  type        String
  fileUrl     String
  driveFileId String?
  uploadedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("documents")
}

// ─────────────────────────────────────────────
// Auditoría
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entity     String
  entityId   String
  oldValues  Json?
  newValues  Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// Sincronización BUK
// ─────────────────────────────────────────────

enum SyncStatus {
  RUNNING
  SUCCESS
  ERROR
}

// ─────────────────────────────────────────────
// Remuneraciones mensuales (desde BUK)
// ─────────────────────────────────────────────

model PayrollEntry {
  id             String      @id @default(uuid())
  employee       Employee    @relation(fields: [employeeId], references: [id])
  employeeId     String
  legalEntity    LegalEntity
  year           Int
  month          Int
  bukPayrollId   Int?
  grossSalary    Int         @default(0)
  liquidSalary   Int         @default(0)
  items          Json        @default("[]")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@unique([employeeId, legalEntity, year, month])
  @@map("payroll_entries")
}

// ─────────────────────────────────────────────
// Onboarding
// ─────────────────────────────────────────────

enum OnboardingPeriod {
  PRE_INGRESO
  DIA_1
  SEMANA_1
  MES_1
  EVALUACION
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskAutomationType {
  MANUAL
  EMAIL
  CALENDAR
  BUK_CHECK
  EXTERNAL
  SHEET_VERIFY
}

enum AutomationStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
}

model OnboardingProcess {
  id                   String           @id @default(uuid())
  // Colaborador libre — no requiere Employee en DB
  collaboratorName          String
  collaboratorEmail         String?
  collaboratorPersonalEmail String?
  collaboratorPosition      String?
  collaboratorPhone         String?
  costCenter                String?
  legalEntity          LegalEntity?
  notes                String?
  // Vinculación opcional a Employee de BUK (se hace después)
  employee             Employee?        @relation(fields: [employeeId], references: [id])
  employeeId           String?
  // Estado del proceso
  status               OnboardingStatus @default(IN_PROGRESS)
  startDate            DateTime
  expectedEndDate      DateTime
  completedAt          DateTime?
  tasks                OnboardingTask[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@map("onboarding_processes")
}

model OnboardingTask {
  id               String             @id @default(uuid())
  process          OnboardingProcess  @relation(fields: [processId], references: [id], onDelete: Cascade)
  processId        String
  templateId       String?            // ID del hito en la plantilla (para trazabilidad)
  period           OnboardingPeriod
  name             String
  tool             String?
  appliesWhen      String?
  sortOrder        Int                @default(0)
  // Automatización
  automationType   TaskAutomationType @default(MANUAL)
  automationConfig Json?              // Configuración específica (email template, calendar config, etc.)
  automationStatus AutomationStatus?
  automationResult Json?              // Resultado del último intento
  automatedAt      DateTime?
  // Completado
  completedAt      DateTime?
  completedBy      String?
  completedNote    String?
  assignments      OnboardingTaskAssignment[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@map("onboarding_tasks")
}

// ─────────────────────────────────────────────
// Perfiles — roles en el ecosistema de onboarding
// ─────────────────────────────────────────────

model Profile {
  id        String        @id @default(uuid())
  name      String
  position  String
  email     String        @unique
  phone     String?
  notes     String?
  roles           ProfileRole[]
  taskAssignments OnboardingTaskAssignment[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("profiles")
}

model OnboardingTaskAssignment {
  id        String         @id @default(uuid())
  task      OnboardingTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId    String
  profile   Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
  roleType  String         // RESPONSABLE_HITO | COPIA_CORREOS | ENVIA_CORREOS | RECIBE_CORREOS | PREPARA_ADM_FISICA
  createdAt DateTime       @default(now())

  @@unique([taskId, profileId, roleType])
  @@map("onboarding_task_assignments")
}

model ProfileRole {
  id        String  @id @default(uuid())
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  profileId String
  area      String  // BUK | SMART | ADMINISTRACION | ACREDITACION | INGRESANTE | JEFATURA | MENTORIA | CHECKPOINTS | GENERAL
  roleType  String  // ENVIA_CORREOS | RECIBE_CORREOS | COPIA_CORREOS | PREPARA_ADM_FISICA | RESPONSABLE_HITO

  @@map("profile_roles")
}

model SyncLog {
  id               String      @id @default(uuid())
  source           String
  legalEntity      LegalEntity
  status           SyncStatus  @default(RUNNING)
  startedAt        DateTime    @default(now())
  completedAt      DateTime?
  employeesTotal   Int         @default(0)
  employeesCreated Int         @default(0)
  employeesUpdated Int         @default(0)
  contractsUpserted Int        @default(0)
  duplicatesSkipped Int        @default(0)
  errorMessage     String?
  errorDetails     Json?

  @@map("sync_logs")
}
