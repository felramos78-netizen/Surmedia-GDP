# =============================================
# GDP Surmedia — Variables de Entorno Backend
# =============================================
# Copia este archivo a .env para desarrollo local
# En Railway: agrega estas variables en el servicio backend → Variables

# --- BASE DE DATOS ---
# En Railway: usar referencia al plugin Postgres → ${{Postgres.DATABASE_URL}}
# Formato: postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/gdp_dev"

# --- AUTENTICACIÓN JWT ---
# Generar con: openssl rand -base64 64
JWT_SECRET="cambia-esto-por-un-string-largo-y-aleatorio-en-produccion"

# --- GOOGLE OAUTH ---
# Crear en: https://console.cloud.google.com → APIs → Credenciales
# URI de redirección autorizada: https://TU-BACKEND.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID="xxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxxxx"
GOOGLE_REDIRECT_URI="https://surmedia-gdp-production.up.railway.app/api/auth/google/callback"

# Solo usuarios de este dominio pueden hacer login
GOOGLE_DOMAIN="surmedia.cl"

# --- URLs DE LA APLICACIÓN ---
# APP_URL = URL del frontend (Vercel)
APP_URL="https://surmedia-gdp.vercel.app"

# --- ENTORNO ---
NODE_ENV="production"

# --- LOGS (opcional) ---
# debug | info | warn | error
LOG_LEVEL="info"
