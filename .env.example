# ================================================
# GDP Surmedia — Variables de Entorno
# Copiar a .env y completar los valores
# NUNCA commitear el archivo .env
# ================================================

# Aplicación
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api

# Base de Datos
DATABASE_URL=postgresql://user:password@localhost:5432/gdp_dev
REDIS_URL=redis://localhost:6379

# Autenticación / JWT
JWT_SECRET=change_this_to_a_random_secret_min_32_chars
JWT_EXPIRES_IN=8h
REFRESH_TOKEN_EXPIRES_IN=7d

# Google OAuth / Workspace
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
GOOGLE_DRIVE_ROOT_FOLDER_ID=root_folder_id_for_employee_docs
GOOGLE_DOMAIN=surmedia.cl

# Microsoft Azure AD (OAuth alternativo)
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_azure_client_id
AZURE_CLIENT_SECRET=your_azure_client_secret
AZURE_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback

# BUK - Comunicaciones Surmedia Spa
BUK_URL_COMUNICACIONES=https://comunicacionessurmedia.buk.cl
BUK_API_KEY_COMUNICACIONES=your_api_key_comunicaciones
BUK_ASISTENCIA_KEY_COMUNICACIONES=your_asistencia_key_comunicaciones
BUK_EDITOR_KEY_COMUNICACIONES=your_editor_key_comunicaciones

# BUK - Surmedia Consultoría Spa
BUK_URL_CONSULTORIA=https://surmediaconsultoria.buk.cl
BUK_API_KEY_CONSULTORIA=your_api_key_consultoria
BUK_ASISTENCIA_KEY_CONSULTORIA=your_asistencia_key_consultoria
BUK_EDITOR_KEY_CONSULTORIA=your_editor_key_consultoria

# BUK compartido
BUK_WEBHOOK_SECRET=secret_for_validating_buk_webhooks

# Previred
PREVIRED_RUT_EMPRESA=12345678-9
PREVIRED_PASSWORD=your_previred_password
PREVIRED_BASE_URL=https://www.previred.com/api

# Trello
TRELLO_API_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_token
TRELLO_ONBOARDING_BOARD_ID=board_id
TRELLO_OFFBOARDING_BOARD_ID=board_id
TRELLO_SELECTION_BOARD_ID=board_id

# Zapier Webhooks (salida desde GDP)
ZAPIER_WEBHOOK_NEW_EMPLOYEE=https://hooks.zapier.com/hooks/catch/...
ZAPIER_WEBHOOK_CONTRACT_END=https://hooks.zapier.com/hooks/catch/...
ZAPIER_WEBHOOK_LEAVE_APPROVED=https://hooks.zapier.com/hooks/catch/...
ZAPIER_WEBHOOK_LEAVE_REJECTED=https://hooks.zapier.com/hooks/catch/...
ZAPIER_INCOMING_SECRET=secret_for_validating_zapier_incoming_webhooks

# Correo transaccional
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rrhh@surmedia.cl
SMTP_PASSWORD=your_app_password
EMAIL_FROM="RRHH Surmedia <rrhh@surmedia.cl>"

# Encriptación (datos sensibles como RUT)
ENCRYPTION_KEY=change_this_to_32_char_hex_string_for_aes256

# Sentry (monitoreo de errores)
SENTRY_DSN=
